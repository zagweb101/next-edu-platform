# ===================================================================
# Boilerplate Environment Variables — copy to .env and fill in
# ===================================================================

# ---- Database (SQLite for local dev, PostgreSQL for Railway) ----
DATABASE_URL="file:/home/z/my-project/db/custom.db"
# For Railway: postgresql://user:pass@roundhouse.proxy.rlwy.net:5432/railway

# ---- NextAuth v5 ----
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
# Google OAuth: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# GitHub OAuth: https://github.com/settings/developers
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# ---- Moyasar Payments (https://dashboard.moyasar.com) ----
MOYASAR_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxx"
MOYASAR_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxx"
MOYASAR_WEBHOOK_SECRET="wh_secret_xxxxxxxxxxxxxxxx"

# ---- Resend Email (https://resend.com/api-keys) ----
RESEND_API_KEY="re_xxxxxxxxxxxxxxxx"
EMAIL_FROM="Boilerplate <noreply@yourdomain.com>"

# ---- Firebase Cloud Messaging (Push Notifications) ----
# Service account JSON (multi-line JSON as a single env var)
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_DATABASE_URL=""

# ---- UploadThing (https://uploadthing.com) ----
UPLOADTHING_SECRET="sk_live_xxxxxxxxxxxxxxxx"
UPLOADTHING_APP_ID="xxxxxxxxxxxxxxxx"

# ---- Redis (for BullMQ queues, rate limiting) ----
# For Railway: redis://default:pass@redis.railway.internal:6379
REDIS_URL="redis://localhost:6379"

# ---- Sentry (https://sentry.io) ----
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# ---- App Config ----
NEXT_PUBLIC_APP_NAME="Next Boilerplate"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_LOCALE="ar"

# ---- Feature Flags (toggle features on/off) ----
NEXT_PUBLIC_ENABLE_PAYMENTS="true"
NEXT_PUBLIC_ENABLE_NOTIFICATIONS="true"
NEXT_PUBLIC_ENABLE_PUS_PUSH="true"
NEXT_PUBLIC_ENABLE_FILE_UPLOADS="true"
