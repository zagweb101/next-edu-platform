// ===================================================================
// Boilerplate Prisma Schema — supports SQLite (local dev) and PostgreSQL (production)
// To switch to PostgreSQL for production:
//   1. Change `provider = "sqlite"` to `provider = "postgresql"`
//   2. Set DATABASE_URL to your Railway Postgres connection string
//   3. Run `bun run db:push`
// See docs/SETUP.md for full instructions.
// ===================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Default: sqlite for local development (zero-config).
  // Switch to "postgresql" when deploying to Railway.
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===================================================================
// Authentication — NextAuth v5 + Prisma Adapter
// ===================================================================

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String? // for credentials provider
  role          Role      @default(STUDENT)
  locale        String    @default("ar") // ar | en
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?

  // Profile (education-specific)
  bio           String?   
  title         String?   // e.g. "Senior React Developer"
  expertise     String?   // for teachers: "Web Development, React"
  socialLinks   Json?     // { twitter, linkedin, github, website }

  // Notification preferences
  notifyEmail   Boolean @default(true)
  notifyPush    Boolean @default(true)
  notifyInApp   Boolean @default(true)

  // FCM tokens (one user can have many devices)
  fcmTokens     FcmToken[]

  accounts      Account[]
  sessions      Session[]
  notifications Notification[]
  auditLogs     AuditLog[]
  payments      Payment[]
  subscriptions Subscription[]
  files         UploadFile[]
  roleAssignments RoleAssignment[]

  // Education relations
  taughtCourses     Course[]
  enrollments       Enrollment[]
  quizAttempts      QuizAttempt[]
  certificates      Certificate[]
  reviews           Review[]

  // Live streaming
  liveSessions      LiveSession[]
  liveAttendances   LiveAttendee[]
  liveChatMessages  LiveChatMessage[]

  // Forum
  forumTopics       ForumTopic[]
  forumPosts        ForumPost[]
  forumTopicLikes   ForumTopicLike[]
  forumPostLikes    ForumPostLike[]

  // Messaging
  conversations     ConversationParticipant[]
  messages          Message[]

  // Coupons
  couponUsages      CouponUsage[]

  // Affiliate
  affiliate         Affiliate?
  affiliateClicks   AffiliateClick[]
  affiliateConversions AffiliateConversion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  ipAddress    String?
  userAgent    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String @unique
  expires    DateTime

  @@id([identifier, token])
}

// ===================================================================
// RBAC — Roles & Permissions (relation table for future multi-role)
// ===================================================================

model RoleAssignment {
  id     String   @id @default(cuid())
  userId String
  role   Role
  scope  String? // optional scope like "team:abc"

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, role, scope])
  @@index([userId])
}

// ===================================================================
// Notifications — In-app + Email + Push
// ===================================================================

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String   @default("info") // info | success | warning | error
  link      String?
  channel   NotificationChannel @default(IN_APP)
  status    NotificationStatus  @default(PENDING)
  metadata  Json?
  readAt    DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, status])
  @@index([createdAt])
}

model FcmToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String?  // web | ios | android
  userAgent String?
  lastUsedAt DateTime?
  isActive  Boolean  @default(true)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isActive])
}

// ===================================================================
// Payments — Moyasar
// ===================================================================

enum PaymentStatus {
  INITIATED
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELED
}

enum PaymentMethod {
  CREDITCARD
  APPLEPAY
  STCPAY
  MADA
}

model Payment {
  id              String   @id @default(cuid())
  userId          String
  moyasarId       String   @unique // moyasar payment id
  amount          Float    // SAR (use Decimal in production with Postgres)
  currency        String   @default("SAR")
  status          PaymentStatus @default(INITIATED)
  method          PaymentMethod?
  description     String?
  source          Json? // full source object from moyasar
  metadata        Json?
  invoiceId       String?
  refundedAmount  Float    @default(0)
  failureReason   String?
  callbackUrl     String?

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription    Subscription?  @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  subscriptionId  String?        @unique
  enrollment      Enrollment?    @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  enrollmentId    String?        @unique
  auditLogs       AuditLog[]
  affiliateConversion AffiliateConversion?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId, status])
  @@index([status])
  @@index([createdAt])
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  EXPIRED
}

model Subscription {
  id               String   @id @default(cuid())
  userId           String
  moyasarId        String?  @unique // moyasar subscription id (token)
  planId           String   // e.g. "pro", "team"
  status           SubscriptionStatus @default(TRIALING)
  amount           Float    // SAR
  currency         String   @default("SAR")
  interval         String   @default("month") // month | year
  currentPeriodEnd DateTime
  canceledAt       DateTime?
  trialEndsAt      DateTime?
  metadata         Json?

  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments         Payment[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([userId, status])
  @@index([status])
}

// ===================================================================
// Audit Log — track all sensitive actions
// ===================================================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String // e.g. "user.login", "payment.refund"
  entity    String? // e.g. "User", "Payment"
  entityId  String?
  ipAddress String?
  userAgent String?
  metadata  Json?
  paymentId String?

  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  payment   Payment?  @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ===================================================================
// UploadThing — track uploaded files metadata
// ===================================================================

model UploadFile {
  id          String   @id @default(cuid())
  userId      String
  fileKey     String   @unique
  fileName    String
  fileSize    Int
  fileType    String
  fileUrl     String
  metadata    Json?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ===================================================================
// System Settings — key/value store for runtime config
// ===================================================================

model Setting {
  key       String   @id
  value     String
  type      String   @default("string") // string | number | boolean | json
  updatedAt DateTime @updatedAt
}

// ===================================================================
// EDUCATION PLATFORM — Courses, Modules, Lessons, Enrollments
// ===================================================================

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ALL_LEVELS
}

model Course {
  id           String       @id @default(cuid())
  title        String
  slug         String       @unique
  description  String       
  whatYouLearn String?       // bullet points separated by \n
  requirements String?       // bullet points separated by \n
  teacherId    String
  teacher      User         @relation(fields: [teacherId], references: [id])
  price        Float        @default(0) // SAR — 0 means free
  comparePrice Float?       // original price for discount display
  level        CourseLevel  @default(BEGINNER)
  language     String       @default("ar") // ar | en
  thumbnail    String?
  previewVideo String?      // URL to preview video
  status       CourseStatus @default(DRAFT)
  isFeatured   Boolean      @default(false)
  duration     Int          @default(0) // total seconds (computed from lessons)
  rating       Float        @default(0) // 0-5 (computed from reviews)
  enrollmentsCount Int      @default(0) // denormalized for performance

  modules      Module[]
  enrollments  Enrollment[]
  reviews      Review[]
  certificates Certificate[]

  // New relations
  liveSessions LiveSession[]
  forumTopics  ForumTopic[]
  coupons      Coupon[]
  affiliateClicks   AffiliateClick[]
  affiliateConversions AffiliateConversion[]

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([teacherId])
  @@index([status])
  @@index([level])
  @@index([isFeatured])
  @@index([createdAt])
}

model Module {
  id        String   @id @default(cuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title     String
  description String?
  order     Int      @default(0)
  lessons   Lesson[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId])
}

enum LessonType {
  VIDEO
  ARTICLE
  PDF
  QUIZ
}

model Lesson {
  id           String    @id @default(cuid())
  moduleId     String
  module       Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  type         LessonType @default(VIDEO)
  videoUrl     String?   // YouTube, Vimeo, or self-hosted URL
  videoProvider String?  // youtube | vimeo | mux | self
  videoDuration Int      @default(0) // seconds
  content      String?    // markdown for ARTICLE type
  pdfUrl       String?
  attachments  Json?     // [{ name, url, size }]
  order        Int       @default(0)
  isPreview    Boolean   @default(false) // free preview lesson
  isPublished  Boolean   @default(true)

  quiz         Quiz?
  progress     LessonProgress[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([moduleId])
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  REFUNDED
  CANCELED
}

model Enrollment {
  id           String           @id @default(cuid())
  courseId     String
  course       Course           @relation(fields: [courseId], references: [id])
  studentId    String
  student      User             @relation(fields: [studentId], references: [id])
  status       EnrollmentStatus @default(ACTIVE)
  progress     Int              @default(0) // percentage 0-100
  paymentId    String?          @unique
  payment      Payment?
  completedAt  DateTime?
  lastAccessedAt DateTime?
  certificate  Certificate?

  lessons      LessonProgress[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([courseId, studentId])
  @@index([studentId])
  @@index([courseId])
  @@index([status])
}

model LessonProgress {
  id              String      @id @default(cuid())
  enrollmentId    String
  enrollment      Enrollment  @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lessonId        String
  lesson          Lesson      @relation(fields: [lessonId], references: [id])
  watchedSeconds  Int         @default(0)
  completed       Boolean     @default(false)
  lastWatchedAt   DateTime    @default(now())

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([enrollmentId, lessonId])
  @@index([enrollmentId])
  @@index([lessonId])
}

model Quiz {
  id        String     @id @default(cuid())
  lessonId  String     @unique
  lesson    Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title     String
  description String?
  passScore Int        @default(70) // %
  maxAttempts Int      @default(3) // 0 = unlimited
  questions Question[]
  attempts  QuizAttempt[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
}

model Question {
  id            String       @id @default(cuid())
  quizId        String
  quiz          Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  type          QuestionType @default(MULTIPLE_CHOICE)
  text          String       
  options       Json         // [{ id: "a", text: "..." }, ...]
  correctAnswer String       // option id (for auto-grading)
  explanation   String?       // shown after answering
  points        Int          @default(1)
  order         Int          @default(0)

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([quizId])
}

model QuizAttempt {
  id          String    @id @default(cuid())
  quizId      String
  quiz        Quiz      @relation(fields: [quizId], references: [id])
  studentId   String
  student     User      @relation(fields: [studentId], references: [id])
  answers     Json      // [{ questionId, selectedOptionId, correct }]
  score       Int       // percentage 0-100
  passed      Boolean
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([quizId])
  @@index([studentId])
}

model Review {
  id        String   @id @default(cuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  studentId String
  student   User     @relation(fields: [studentId], references: [id])
  rating    Int      // 1-5
  comment   String?  

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([courseId, studentId]) // one review per course per student
  @@index([courseId])
}

model Certificate {
  id              String      @id @default(cuid())
  enrollmentId    String      @unique
  enrollment      Enrollment  @relation(fields: [enrollmentId], references: [id])
  studentId       String
  student         User        @relation(fields: [studentId], references: [id])
  courseId        String
  course          Course      @relation(fields: [courseId], references: [id])
  certificateNumber String    @unique
  issuedAt        DateTime    @default(now())

  @@index([studentId])
  @@index([courseId])
}

// ===================================================================
// LIVE STREAMING — Zoom integration + WebRTC fallback
// ===================================================================

enum LiveSessionStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELED
}

enum LiveProvider {
  ZOOM
  WEBRTC
  YOUTUBE
  VIMEO
}

model LiveSession {
  id              String           @id @default(cuid())
  title           String
  description     String?
  courseId        String?
  course          Course?          @relation(fields: [courseId], references: [id])
  teacherId       String
  teacher         User             @relation(fields: [teacherId], references: [id])
  provider        LiveProvider     @default(WEBRTC)
  status          LiveSessionStatus @default(SCHEDULED)
  scheduledStart  DateTime
  scheduledEnd    DateTime?
  actualStart     DateTime?
  actualEnd       DateTime?
  // Provider-specific
  zoomMeetingId   String?
  zoomJoinUrl     String?
  zoomStartUrl    String?
  zoomPassword    String?
  webrtcRoomId    String?          // unique room id for WebRTC
  youtubeLiveUrl  String?
  // Stats
  maxViewers      Int              @default(0)
  attendees       LiveAttendee[]
  chatMessages    LiveChatMessage[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([teacherId])
  @@index([courseId])
  @@index([status])
  @@index([scheduledStart])
}

model LiveAttendee {
  id            String      @id @default(cuid())
  liveSessionId String
  liveSession   LiveSession @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt      DateTime    @default(now())
  leftAt        DateTime?
  duration      Int         @default(0) // seconds

  @@unique([liveSessionId, userId])
  @@index([liveSessionId])
  @@index([userId])
}

model LiveChatMessage {
  id            String      @id @default(cuid())
  liveSessionId String
  liveSession   LiveSession @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  message       String
  isPinned      Boolean     @default(false)
  isDeleted     Boolean     @default(false)
  createdAt     DateTime    @default(now())

  @@index([liveSessionId, createdAt])
  @@index([userId])
}

// ===================================================================
// DISCUSSION FORUMS — Topics + Posts + Likes
// ===================================================================

model ForumCategory {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String?
  color       String?       // hex color for badge
  order       Int           @default(0)
  topics      ForumTopic[]
  createdAt   DateTime      @default(now())

  @@index([order])
}

model ForumTopic {
  id           String         @id @default(cuid())
  categoryId   String
  category     ForumCategory  @relation(fields: [categoryId], references: [id])
  courseId     String?        // optional: link to specific course
  course       Course?        @relation(fields: [courseId], references: [id])
  authorId     String
  author       User           @relation(fields: [authorId], references: [id])
  title        String
  slug         String         @unique
  content      String
  isPinned     Boolean        @default(false)
  isLocked     Boolean        @default(false)
  isSolved     Boolean        @default(false)
  viewsCount   Int            @default(0)
  postsCount   Int            @default(0)
  posts        ForumPost[]
  likes        ForumTopicLike[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([categoryId])
  @@index([authorId])
  @@index([createdAt])
}

model ForumPost {
  id          String   @id @default(cuid())
  topicId     String
  topic       ForumTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  content     String
  isSolution  Boolean  @default(false)
  likes       ForumPostLike[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([topicId, createdAt])
  @@index([authorId])
}

model ForumTopicLike {
  id        String     @id @default(cuid())
  topicId   String
  topic     ForumTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@unique([topicId, userId])
}

model ForumPostLike {
  id        String    @id @default(cuid())
  postId    String
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([postId, userId])
}

// ===================================================================
// DIRECT MESSAGING — Conversations + Messages
// ===================================================================

model Conversation {
  id           String      @id @default(cuid())
  // For 1-on-1 chats: 2 participants. For group: more.
  participants ConversationParticipant[]
  messages     Message[]
  lastMessageAt DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([lastMessageAt])
}

model ConversationParticipant {
  id              String        @id @default(cuid())
  conversationId  String
  conversation    Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role            String        @default("member") // admin | member
  lastReadAt      DateTime?
  muted           Boolean       @default(false)
  createdAt       DateTime      @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id              String       @id @default(cuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId        String
  sender          User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content         String
  attachments     Json?        // [{ type, url, name, size }]
  replyToId       String?
  replyTo         Message?     @relation("MessageReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies         Message[]    @relation("MessageReply")
  isEdited        Boolean      @default(false)
  isDeleted       Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([conversationId, createdAt])
  @@index([senderId])
}

// ===================================================================
// COUPON CODES — Discount codes for course enrollment
// ===================================================================

enum CouponType {
  PERCENTAGE
  FIXED
}

model Coupon {
  id              String     @id @default(cuid())
  code            String     @unique
  description     String?
  type            CouponType
  value           Float      // percentage (0-100) or fixed amount in SAR
  maxUses         Int        @default(0) // 0 = unlimited
  maxUsesPerUser  Int        @default(1)
  usedCount       Int        @default(0)
  // Optional: limit to specific course
  courseId        String?
  course          Course?    @relation(fields: [courseId], references: [id])
  // Optional: minimum order amount
  minAmount       Float?
  // Validity window
  validFrom       DateTime   @default(now())
  validUntil      DateTime?
  isActive        Boolean    @default(true)
  usages          CouponUsage[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([code])
  @@index([courseId])
  @@index([isActive])
}

model CouponUsage {
  id          String   @id @default(cuid())
  couponId    String
  coupon      Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  courseId    String?
  orderId     String?  // payment id or enrollment id
  discountAmount Float // actual discount applied
  createdAt   DateTime @default(now())

  @@unique([couponId, userId, courseId])
  @@index([couponId])
  @@index([userId])
}

// ===================================================================
// AFFILIATE PROGRAM — Referral links + tracking + payouts
// ===================================================================

enum AffiliateStatus {
  ACTIVE
  SUSPENDED
  PENDING_PAYOUT
  PAID
}

model Affiliate {
  id              String          @id @default(cuid())
  userId          String          @unique // one affiliate account per user
  user            User            @relation(fields: [userId], references: [id])
  referralCode    String          @unique
  commissionRate  Float           @default(10) // percentage 0-100
  status          AffiliateStatus @default(ACTIVE)
  // Stats (denormalized)
  totalClicks     Int             @default(0)
  totalSignups    Int             @default(0)
  totalConversions Int            @default(0)
  totalEarnings   Float           @default(0) // SAR
  paidOut         Float           @default(0) // SAR
  pendingBalance  Float           @default(0) // SAR
  // Relations
  clicks          AffiliateClick[]
  conversions     AffiliateConversion[]
  payouts         AffiliatePayout[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([referralCode])
  @@index([status])
}

model AffiliateClick {
  id            String    @id @default(cuid())
  affiliateId   String
  affiliate     Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  // The user who clicked (if logged in). null for anonymous
  userId        String?
  user          User?     @relation(fields: [userId], references: [id])
  // What they were referred to (course, generic landing, etc)
  targetUrl     String
  courseId      String?
  course        Course?   @relation(fields: [courseId], references: [id])
  // Tracking
  ipAddress     String?
  userAgent     String?
  referrer      String?
  converted     Boolean   @default(false)
  conversion    AffiliateConversion?
  createdAt     DateTime  @default(now())

  @@index([affiliateId])
  @@index([userId])
  @@index([createdAt])
}

enum ConversionType {
  SIGNUP
  ENROLLMENT
  PURCHASE
}

model AffiliateConversion {
  id            String         @id @default(cuid())
  affiliateId   String
  affiliate     Affiliate      @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  referredUserId String?
  user          User?          @relation(fields: [referredUserId], references: [id])
  courseId      String?
  course        Course?        @relation(fields: [courseId], references: [id])
  paymentId     String?        @unique
  payment       Payment?       @relation(fields: [paymentId], references: [id])
  type          ConversionType
  amount        Float          // order amount
  commission    Float          // commission earned
  status        AffiliateStatus @default(PENDING_PAYOUT)
  click         AffiliateClick? @relation(fields: [clickId], references: [id])
  clickId       String?        @unique
  createdAt     DateTime       @default(now())

  @@index([affiliateId])
  @@index([status])
}

model AffiliatePayout {
  id            String    @id @default(cuid())
  affiliateId   String
  affiliate     Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  amount        Float     // SAR
  method        String    @default("bank_transfer") // bank_transfer | paypal | stripe
  status        String    @default("pending") // pending | completed | failed
  reference     String?   // transaction reference
  notes         String?   // JSON-encoded array of conversion IDs
  paidAt        DateTime?
  createdAt     DateTime  @default(now())

  @@index([affiliateId])
  @@index([status])
}

// ===================================================================
// MULTI-CURRENCY — Conversion rates + user preferences
// ===================================================================

model Currency {
  code        String   @id // ISO 4217: USD, SAR, EUR, AED, etc.
  name        String
  symbol      String
  exchangeRate Float   @default(1) // rate relative to base currency (SAR)
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt

  @@index([isActive])
}
